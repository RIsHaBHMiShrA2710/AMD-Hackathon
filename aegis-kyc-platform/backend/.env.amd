# AMD AI Developer Cloud — Environment Configuration
# Copy this to .env before starting the backend in the pod
#
# ── AMD Notebook Pod Settings ─────────────────────────────────────────────────
# vLLM runs inside the same pod at localhost:8000
# Started with: VLLM_USE_TRITON_FLASH_ATTN=0 vllm serve Qwen/Qwen3-4B \
#               --served-model-name Qwen3-4B --api-key abc-123 --port 8000 \
#               --enable-auto-tool-choice --tool-call-parser Hermes \
#               --trust-remote-code --max_model_len 24272

AMD_INFERENCE_URL=http://localhost:8000/v1
AMD_API_KEY=abc-123
LLM_MODEL=Qwen3-4B
LLM_TIMEOUT=60.0

# ── Local Dev Fallback (comment out above and use this for local testing) ──────
# VLLM_BASE_URL=http://localhost:8000/v1
# AMD_API_KEY=
# LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
